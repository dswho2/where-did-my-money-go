SECRET_KEY=your-secret-key-here
# Local dev only — production defaults to False (never set DEBUG=True in Vercel)
DEBUG=True
# Local dev: localhost,127.0.0.1
# Production: add your Vercel backend domain, e.g. my-api.vercel.app
ALLOWED_HOSTS=localhost,127.0.0.1

# Neon Postgres — copy the connection string from your Neon dashboard
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# Frontend origin for CORS (comma-separated if multiple)
FRONTEND_ORIGINS=http://localhost:5173

# -----------------------------------------------------------------
# Teller API credentials — choose ONE of the two options below
# -----------------------------------------------------------------

# Option A: file paths — easiest for local dev
# TELLER_CERT_PATH=/path/to/certificate.pem
# TELLER_PRIVATE_KEY_PATH=/path/to/private_key.pem

# Option B: paste PEM content inline — required for Vercel/production
# Open certificate.pem and private_key.pem in a text editor,
# copy the full content (including the -----BEGIN/END----- lines),
# and paste it as the value. Works in both .env and Vercel's env var UI.
# TELLER_CERT="-----BEGIN CERTIFICATE-----
# MIIDxxx...
# -----END CERTIFICATE-----"
# TELLER_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
# MIIExx...
# -----END PRIVATE KEY-----"

# Cron job secret — Vercel sends this as "Authorization: Bearer <value>"
# Generate with: openssl rand -hex 32
# CRON_SECRET=your-random-secret-here
